# Ozon ERP 环境变量配置

# ============================================
# Ozon API 配置
# ============================================

# 主店铺配置
OZON_CLIENT_ID=你的ClientID
OZON_API_KEY=你的API密钥

# 多店铺配置（可选，JSON格式）
# OZON_SHOPS=[{"id":"shop1","clientId":"xxx","apiKey":"xxx","name":"店铺1"},{"id":"shop2","clientId":"yyy","apiKey":"yyy","name":"店铺2"}]

# ============================================
# API 配置
# ============================================

# Ozon API 基础URL
OZON_API_BASE_URL=https://api-seller.ozon.ru

# API 请求超时（毫秒）
OZON_API_TIMEOUT=30000

# API 重试次数
OZON_API_RETRIES=3

# ============================================
# 订单同步配置
# ============================================

# 订单同步间隔（分钟）
ORDER_SYNC_INTERVAL=30

# 订单同步批次大小
ORDER_SYNC_BATCH_SIZE=100

# 默认同步状态（Ozon订单状态）
ORDER_SYNC_DEFAULT_STATUS=awaiting_packaging

# ============================================
# 业务配置
# ============================================

# 售后期天数（利润核算在售后期结束后进行）
AFTER_SALE_PERIOD_DAYS=14

# 备货建议阈值：近30天销量
RESTOCK_SALES_THRESHOLD=50

# 备货建议阈值：利润率
RESTOCK_PROFIT_RATE_THRESHOLD=0.15

# ============================================
# 数据库配置（Supabase）
# ============================================

NEXT_PUBLIC_SUPABASE_URL=你的SupabaseURL
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的Supabase匿名密钥
SUPABASE_SERVICE_ROLE_KEY=你的Supabase服务密钥

# ============================================
# 其他配置
# ============================================

# 日志级别
LOG_LEVEL=info

# 是否启用调试模式
DEBUG=false
